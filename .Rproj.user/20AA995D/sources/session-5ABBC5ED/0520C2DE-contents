

.reveal .math,
.reveal mjx-container {
  font-size: 100%;
  font-weight: 100;
}

.reveal .columns .callout {
  margin-top: 0em !important;
  margin-bottom: 0.2em !important;
}

.reveal .column {
  padding-top: 0 !important;
  margin-top: 0 !important;
}

.reveal .columns { align-items: flex-start !important; margin-bottom: 0.2em !important; }
.reveal .columns + p, .reveal .columns + ul { margin-top: 0.2em !important; }


.wrap-right {
  float: right;
  width: 40%;
  margin-left: 1em;
}

.reveal .slides section.title-slide .title {
  font-weight: 900 !important;
}

.reveal .slides section.title-slide p.subtitle {
  font-weight: 300 !important;
}

/* Reduce spacing in author / affiliation block */
.reveal .slides section.title-slide .quarto-title-authors {
  margin-top: 0.5em !important;
  gap: 0.2em !important;
}

/* Author name */
.reveal .slides section.title-slide .quarto-title-author-name {
  margin-bottom: 0.1em !important;
  line-height: 1.1 !important;
}

/* Affiliation */
.reveal .slides section.title-slide .quarto-title-affiliation {
  margin-top: 0 !important;
  line-height: 1.1 !important;
  opacity: 0.9;
}

/* Reduce overall block spacing */
.reveal .slides section.title-slide .quarto-title-meta {
  margin-top: 0.5em !important;
}


/* 1) Left-align all text on the title slide */
.reveal .slides section.title-slide,
.reveal .slides section.title-slide * {
  text-align: left !important;
}

/* FRONT PAGE ONLY: first slide that contains the title block */
.reveal .slides section:has(.title) {
  position: relative !important;
}

/* But only the very first matching one */
.reveal .slides section:has(.title):not(:has(section:has(.title))) {
  /* no-op; keeps specificity sane */
}

/* Safer approach: use your custom class instead (recommended) */

/* Title */
.reveal .slides > section:first-of-type .title {
  position: absolute !important;
  left: -2rem !important;
  top: 10vh !important;
  transform: none !important;
  text-align: left !important;
  width: min(60rem, 80vw) !important;
}

/* Subtitle */
.reveal .slides > section:first-of-type .subtitle {
  position: absolute !important;
  left: -2rem !important;
  top: 22vh !important;
  transform: none !important;
  text-align: left !important;
  width: min(60rem, 80vw) !important;
}

/* Author/affiliation */
.reveal .slides > section:first-of-type .quarto-title-meta,
.reveal .slides > section:first-of-type .quarto-title-authors {
  position: absolute !important;
  left: -2rem !important;
  top: 36vh !important;
  transform: none !important;
  text-align: left !important;
  width: min(60rem, 80vw) !important;
}

/* Card description (fix readability) */
/* Force EVERYTHING inside the card to use the slide font */
.reveal .app-card,
.reveal .app-card * {
  font: inherit !important;          /* stronger than font-family */
}

/* Then re-apply your sizes */
.reveal .app-title{
  font-size: 1.1em;
  font-weight: 700;
  margin-bottom: 8px;
}

.reveal .app-desc{
  font-size: 0.9em;
  font-weight: 400;
  line-height: 1.25;
  opacity: .85;
}

.reveal .figure {
  margin-top: 0;
  margin-bottom: 0.5rem;
}

.reveal figcaption {
  margin-top: 0.25rem;
}


