<section id="eki-pseudocódigo" class="slide level2">
<h2>EKI: pseudocódigo</h2>
<div class="sourceCode" id="cb1"><pre class="sourceCode numberSource {pseudocode} number-lines code-with-copy"><code class="sourceCode"><span id="cb1-1"><a></a>\begin{algorithm}</span>
<span id="cb1-2"><a></a>\caption{Ensemble Kalman Inversion (EKI)}</span>
<span id="cb1-3"><a></a>\begin{algorithmic}</span>
<span id="cb1-4"><a></a>\STATE Sample $u_0^{(j)} \sim \pi_0(u)$ for $j=1,\dots,J$</span>
<span id="cb1-5"><a></a>\FOR{$n=0,1,\dots,N-1$}</span>
<span id="cb1-6"><a></a>  \STATE Evaluate $y_n^{(j)}=\mathcal{G}(u_n^{(j)})$</span>
<span id="cb1-7"><a></a>  \STATE Compute empirical covariances $C_n^{up}$, $C_n^{pp}$</span>
<span id="cb1-8"><a></a>  \FOR{$j=1,\dots,J$}</span>
<span id="cb1-9"><a></a>    \STATE $u_{n+1}^{(j)} \leftarrow u_n^{(j)} + C_n^{up}(C_n^{pp}+\Gamma)^{-1}(y^{obs}-y_n^{(j)})$</span>
<span id="cb1-10"><a></a>  \ENDFOR</span>
<span id="cb1-11"><a></a>\ENDFOR</span>
<span id="cb1-12"><a></a>\STATE Return ensemble $\{u_N^{(j)}\}_{j=1}^J$ and summaries</span>
<span id="cb1-13"><a></a>\end{algorithmic}</span>
<span id="cb1-14"><a></a>\end{algorithm}</span></code><button title="Copy to Clipboard" class="code-copy-button"><i class="bi"></i></button></pre></div>
